From 2eff2f5851843516e97a15be72b0d0c0f1f4c9a7 Mon Sep 17 00:00:00 2001
From: arches-toolkit <toolkit@flaxandteal.co.uk>
Date: Tue, 14 Apr 2026 22:11:01 +0100
Subject: [PATCH] frontend_configuration: honour
 ARCHES_FRONTEND_CONFIGURATION_DIR env var
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Projects and deployments currently have no way to relocate the output of
generate_frontend_configuration() — the four JSON files produced on app
startup. The location is computed as "<base_path>/../frontend_configuration",
i.e. a sibling of the Arches or project source tree.

That forces container images to keep the path writable at runtime, which in
turn forces them to run as root or to relax readOnlyRootFilesystem in
Kubernetes. Neither is acceptable for a modern deployment posture.

This patch lets the path be overridden via an environment variable,
ARCHES_FRONTEND_CONFIGURATION_DIR. When set, the four generators write into
it directly; the directory is created on demand (os.makedirs exist_ok=True
is already how it was handled before). When not set, behaviour is
unchanged, so existing checkouts and docs continue to work.

The intended use is to point the env var at a named volume, tmpfs, or
emptyDir that lives outside the code tree. The Arches source can then be
installed into a read-only filesystem.

Upstream: none yet
Last-reviewed: 2026-04-14
Reason: Let ARCHES_FRONTEND_CONFIGURATION_DIR relocate the runtime-writable
  frontend_configuration directory off the code tree, so containers can run
  non-root with read-only root filesystems in Kubernetes.
---
 .../generate_frontend_configuration.py        | 37 ++++++++++++++-----
 1 file changed, 28 insertions(+), 9 deletions(-)

diff --git a/arches/app/utils/frontend_configuration_utils/generate_frontend_configuration.py b/arches/app/utils/frontend_configuration_utils/generate_frontend_configuration.py
index e44af05..cb10794 100644
--- a/arches/app/utils/frontend_configuration_utils/generate_frontend_configuration.py
+++ b/arches/app/utils/frontend_configuration_utils/generate_frontend_configuration.py
@@ -14,17 +14,36 @@ from arches.app.utils.frontend_configuration_utils.generate_webpack_configuratio
 from arches.app.utils.frontend_configuration_utils.get_base_path import get_base_path
 
 
+FRONTEND_CONFIGURATION_DIR_ENV_VAR = "ARCHES_FRONTEND_CONFIGURATION_DIR"
+
+
+def _frontend_configuration_dir(base_path):
+    """Resolve the output directory for generated frontend configuration.
+
+    If the ``ARCHES_FRONTEND_CONFIGURATION_DIR`` environment variable is set,
+    use it verbatim. This lets deployments relocate the runtime-writable
+    directory off the Arches source tree so containers can run non-root with
+    read-only root filesystems.
+
+    Otherwise fall back to the historical location (``<base_path>/..
+    /frontend_configuration``) for backward compatibility with existing
+    checkouts and docs.
+    """
+    override = os.environ.get(FRONTEND_CONFIGURATION_DIR_ENV_VAR)
+    if override:
+        return os.path.realpath(override)
+    return os.path.realpath(os.path.join(base_path, "..", "frontend_configuration"))
+
+
 def _generate_frontend_configuration_directory(base_path):
-    destination_dir = os.path.realpath(
-        os.path.join(base_path, "..", "frontend_configuration")
-    )
+    destination_dir = _frontend_configuration_dir(base_path)
 
     os.makedirs(destination_dir, exist_ok=True)
 
 
 def _generate_urls_json_file(base_path):
-    destination_file_path = os.path.realpath(
-        os.path.join(base_path, "..", "frontend_configuration", "urls.json")
+    destination_file_path = os.path.join(
+        _frontend_configuration_dir(base_path), "urls.json"
     )
 
     with open(destination_file_path, "w", encoding="utf-8") as destination_file:
@@ -39,8 +58,8 @@ def _generate_urls_json_file(base_path):
 
 
 def _generate_webpack_configuration_file(base_path):
-    destination_path = os.path.realpath(
-        os.path.join(base_path, "..", "frontend_configuration", "webpack-metadata.json")
+    destination_path = os.path.join(
+        _frontend_configuration_dir(base_path), "webpack-metadata.json"
     )
 
     with open(destination_path, "w", encoding="utf-8") as file:
@@ -52,8 +71,8 @@ def _generate_webpack_configuration_file(base_path):
 
 
 def _generate_tsconfig_paths_file(base_path):
-    destination_path = os.path.realpath(
-        os.path.join(base_path, "..", "frontend_configuration", "tsconfig-paths.json")
+    destination_path = os.path.join(
+        _frontend_configuration_dir(base_path), "tsconfig-paths.json"
     )
 
     with open(destination_path, "w", encoding="utf-8") as file:
